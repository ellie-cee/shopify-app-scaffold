#!/usr/bin/env python3

import os
import pathlib
import sys
import uuid
BASE_DIR = pathlib.Path(__file__).resolve().parent.parent
sys.path.append(str(BASE_DIR))

import datetime

import string

import json
from urllib.parse import urlparse
from password_generator import PasswordGenerator
import subprocess
import toml
import json

from slugify import slugify
import argparse
import secrets
from jinja2 import Environment, FileSystemLoader
import pyinputplus as pyip
from app.esc.data import Searchable


parser = argparse.ArgumentParser()


for path in ["tmp","files","shopify_app"]:
    dir = pathlib.Path(os.path.join(BASE_DIR,path))
    if not dir.exists():
        dir.mkdir()


DATABASES = pathlib.Path(os.path.join(BASE_DIR,".database_profiles.json"))
ENV_FILE = pathlib.Path(os.path.join(BASE_DIR,".env"))
TEMPLATES = pathlib.Path(os.path.join(BASE_DIR,"templates","configs"))
TMPFILES = pathlib.Path(os.path.join(BASE_DIR,"tmp"))
LOGDIR = pathlib.Path(os.path.join(BASE_DIR,"logs"))
APP_DIR = os.path.join(BASE_DIR,"esc")
CONFIG_DIR = os.path.join(BASE_DIR,"templates","configs")
CONFIG_CACHE = pathlib.Path(os.path.join(BASE_DIR,".config-cache.json"))
environmentLoader = Environment(loader=FileSystemLoader(CONFIG_DIR))

API_VERSION = "2026-01"

class Configurator(object):
    def __init__(self,**kwargs):
        self.args = kwargs
        self.sysConfig = None
        self.config = {}
        self.env = self.loadEnv()
        if DATABASES.exists():
            try:
                self.databases = json.load(open(DATABASES))
            except:
                self.databases = {}
        else:
            self.databases = {}
        for folder in [TMPFILES,LOGDIR]:
            if not folder.exists():
                folder.mkdir()
    def run(self):
        self.type = slugify(pyip.inputMenu(
            prompt="Select Config Type: \n",
            choices=[
                "ETL",
                "Custom App",
                "Unlisted App",
            ],
            numbered=True,

        ))
        if self.type == "etl":
            self.buildEtlApp()
        else:
            self.buildShopifyApp()
    def readTemplate(self,name):
        file = pathlib.Path(os.path.join(TEMPLATES,name))
        if file.exists():
            if file.name.lower().endswith("json"):
                return json.load(open(file))
            return open(file).read()
        else:
            return ""
    def parseEnvFile(self,path:pathlib.Path,existing={}) -> dict:
        env = {}
        if path.exists():
            with open(path) as file:
                for line in file.readlines():
                    key,value,*rest = line.split("=")
                    if key in existing:
                        env[key] = existing[key]
                    else:
                        env[key] = value
        return env

    def defaultEnv(self,existing={}):
        return self.parseEnvFile(
            pathlib.Path(os.path.join(TEMPLATES,"env-default")),
            existing=existing
        )
    def buildEnv(self,values={}):
        env = self.parseEnvFile(ENV_FILE)|values
        template:dict = self.readTemplate("env-template.json")
        
        value:dict
        for key,value in template.items():
            if value.get("choices") is not None:
                env[key] = pyip.inputMenu(
                    prompt=f'{value.get("label")}: ',
                    choices=value.get("choices"),
                    numbered=True
                )
            elif value.get("autogenerate"):
                env[key] = str(uuid.uuid4())
            else:
                env[key] = self.getText(
                    value.get("label"),
                    key,
                    env,
                    allowBlank=value.get("blank",False),
                    defaultValue=env.get(key).strip() if key in env else value.get("default")
                )
        return env           

                    



    def loadEnv(self):
        return self.parseEnvFile(pathlib.Path(os.path.join(BASE_DIR,".env")))
    def get(self,key,default=None):
        if self.args.get(key):
            return self.args.get(key)
        return default
    def set(self,key,value):
        self.args[key] = value    
    def write(self,name,content):
        path = pathlib.Path(os.path.join(BASE_DIR,name))
        with open(path,"w") as file:
            file.write(content)
    def generatePassword(self,length):
        characters = string.ascii_letters + string.digits + string.punctuation
        secure_password = ''.join(secrets.choice(characters) for i in range(length))
        return secure_password
    def proceed(self,prompt):
        return pyip.inputMenu(
            prompt=f"{prompt}\n",
            choices=["Yes","No"],
            numbered=True
        )=="Yes"
    def getText(self,prompt,key,input,allowBlank=False,defaultValue=None):
        showPrompt = f"{prompt}"
        if input.get(key) is not None:
            showPrompt = f"{showPrompt} ({input.get(key).strip()}): "
        else:
            showPrompt = f"{showPrompt}: "
        if defaultValue is None:
            defaultValue = input.get(key,"")

        result =  pyip.inputStr(
                prompt=showPrompt,
                default=defaultValue,
                blank=True if input.get(key) is not None or allowBlank else False
            )
        if not result:
            result = defaultValue

        return result
        
        
    def buildShopifyProfile(self,profile:Searchable):
        profile.set(
            "SHOPIFY_CLIENT_ID",
            self.getText("Client ID","SHOPIFY_CLIENT_ID",profile)
        )
        profile.set(
            "SHOPIFY_CLIENT_SECRET",
            self.getText("Client Secret","SHOPIFY_CLIENT_SECRET",profile)
        )
        profile.set(
            "SHOPIFY_API_VERSION",
            self.getText("API Version","SHOPIFY_API_VERSION",profile)
        )
        return profile
        
    def buildDatabaseProfile(self,name):
        database = self.databases.get(name)
        if database is not None:
            if not self.proceed(f"Database {name} exists. Rebuild?"):
                return database
            self.runSql(
                f"delete-{name}.sql",
                f"""
                DROP DATABASE IF EXISTS `{database.get("name")}`;
                """
            )
        config = {
            "host":self.getText("DB Host","DB_HOST",database),
            "name":self.getText("DB Name","DB_NAME",database),
            "password":str(uuid.uuid4()),
        }
        config["user"] = f"{config.get("name")}_user"
        self.runSql(
            "create-database.sql",
            f""" 
                DROP DATABASE IF EXISTS `{config.get('name')}`;
                CREATE DATABASE `{config.get('name')}`  DEFAULT CHARSET = utf8mb4 DEFAULT COLLATE = utf8mb4_unicode_ci;
                DROP USER IF EXISTS `{config.get('user')}`@`localhost`;
                create user `{config.get('user')}`@`localhost` IDENTIFIED BY '{config.get('password')}';
                GRANT ALL PRIVILEGES on {config.get('name')}.* to `{config.get('user')}`@`localhost`;
                flush privileges;
            """
        )
        self.databases[name] = config
        with(open(DATABASES,"w")) as dbfile:
            json.dump(self.databases,dbfile)
        return config
    def populateDatabase(self,profile):
        files = list(
            map(
                lambda x:str(x.resolve()),
                pathlib.Path("./").glob("*.sql")
            )
        )
        if len(files)<1:
            return
        popfile = pyip.inputMenu(
            prompt="Populate Database? \n",
            choices = files+["No"],
            numbered=True

        )
        if popfile == "No":
            return
        print(f"Populating {profile.get('name')} from {popfile}. Please wait")
        os.system(f"sudo mysql {profile.get("name")} < {popfile}")

    def runSql(self,name,contents):
        sqlPath = os.path.join(BASE_DIR,name)
        with open(sqlPath,"w") as file:
            file.write(contents)
        
        os.system(f"sudo mysql < {sqlPath}")
        pathlib.Path(sqlPath).unlink()        

    def writeEnv(self,items:dict):
        Searchable(items).dump()
        self.write(
            ".env",
            "\n".join([f"{key}={value}" for key,value in items.items()])
        )
    def buildEtlApp(self):
        apiConfig = Searchable
        


        env = {
            "PROJECT_NAME":pyip.inputStr("Project Name: ",blank=False),
            "DJANGO_SETTINGS_MODULE":"EscMTDjango.settings",
            "PYTHONPATH":"./:./bin:./pbin",
            "PATH":f"{os.environ.get("PATH")}:./bin:./pbin"
        }
        print("Building Default Shopify Profile")
        self.buildShopifyProfile(apiConfig,"default")
        while self.proceed("Create another profile?"):
            self.buildShopifyProfile(
                pyip.inputStr("Profile Name: ",blank=False)
            )
        print("Building default database")
        defaultDB = self.buildDatabaseProfile("default")
        env["DB_NAME"] = defaultDB.get("name")
        env["DB_HOST"] = defaultDB.get("host")
        env["DB_USER"] = defaultDB.get("user")
        env["DB_PASSWORD"] = defaultDB.get("password")
        while self.proceed("Create another database?"):
            newDB = self.buildDatabaseProfile(
                pyip.inputStr("Profile Name: ",blank=False)
            )
            self.populateDatabase(newDB)
        with open(DATABASES,"w") as file:
            json.dump(self.databases,file)
        self.writeEnv(env)
    def buildShopifyApp(self):
        configCache = json.load(open(CONFIG_CACHE)) if CONFIG_CACHE.exists() else {}
        projectName = self.getText("Project Name","APP_NAME",configCache)
        hostname = self.getText("Project Domain","APP_DOMAIN",configCache)
        
        env = self.buildEnv(values=configCache)
        apiConfig = Searchable.load(DATABASES)
        shopifyProfile = self.buildShopifyProfile(Searchable(configCache))

        config = {
            "project_root":APP_DIR,
            "project_wsgi_port":self.getText("WSGI Port","project_wsgi_port",configCache),
            "project_domain": hostname,
            "project_slug":  slugify(projectName),
            "project_name": projectName,
            "project_user":self.getText("Project User","project_user",configCache),
            "project_group":self.getText("Project Group","project_group",configCache),
            "project_base_class":self.getText("Base Class","project_base_class",configCache)
        }
        
        config["APP_HOST"] = f"127.0.0.1:{config.get("wsgi_port")}"
        print("Building default database")
        defaultDB = self.buildDatabaseProfile("default")
        env["DB_NAME"] = defaultDB.get("name")
        env["DB_HOST"] = defaultDB.get("host")
        env["DB_USER"] = defaultDB.get("user")
        env["DB_PASSWORD"] = defaultDB.get("password")

        env["SHOPIFY_CLIENT_ID"] = shopifyProfile.get("SHOPIFY_CLIENT_ID")
        env["SHOPIFY_CLIENT_SECRET"] = shopifyProfile.get("SHOPIFY_CLIENT_SECRET")
        env["SHOPIFY_API_VERSION"] = shopifyProfile.get("SHOPIFY_API_VERSION")
        env["APP_DOMAIN"] = hostname
        env["APP_NAME"] = projectName

        for key,value in env.items():
            config[key] = value
        for key,value in shopifyProfile.dict().items():
            config[key] = value

        self.writeEnv(env)
        with open(CONFIG_CACHE,"w") as cfile:
            json.dump(config,cfile)

        self.write(
            "tmp/nginx.conf",
            environmentLoader.get_template('nginx.conf').render(config),    
        )
        self.write(
            "tmp/uwsgi.ini",
            environmentLoader.get_template('uwsgi.ini').render(config),
        )
        self.write(
            "tmp/systemd.service",
            environmentLoader.get_template('systemd-app.service').render(config),    
        )
    def buildCustomApp(self):
        pass
Configurator().run()