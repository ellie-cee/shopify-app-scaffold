[Unit]
    Description=uWSGI instance to serve {{project_name}}
    After=network.target

    [Service]
    User={{ project_user }}
    Group={{ project_group }}
    WorkingDirectory={{project_dir}}/app
    ExecStart=/usr/local/bin/pipenv run uwsgi --ini uwsgi.ini
    Restart=always

    [Install]
    WantedBy=multi-user.target
